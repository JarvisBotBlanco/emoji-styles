{
  "name": "emoji-styles-cli",
  "private": true,
  "version": "0.1.0",
  "description": "Deterministic project setup, validation, asset sync, and provider tooling for Emoji Styles",
  "engines": { "node": ">=18.17" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "emoji-styles": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/config": "./schemas/emoji-styles-config.schema.json"
  },
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --external emoji-styles",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "emoji-styles": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blancochuy/emoji-styles.git",
    "directory": "packages/cli"
  },
  "license": "MIT"
}
