{
  "name": "emoji-styles",
  "private": true,
  "version": "0.1.0",
  "description": "Typed emoji resolution, semantic asset mappings, and licensed multi-provider fallbacks",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/provider": "./schemas/emoji-provider.schema.json"
  },
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "emoji-styles-data": "workspace:*"
  },
  "devDependencies": {
    "emoji-styles-test-fixtures": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "repository": { "type": "git", "url": "git+https://github.com/Blancochuy/emoji-styles.git", "directory": "packages/core" },
  "bugs": { "url": "https://github.com/Blancochuy/emoji-styles/issues" },
  "homepage": "https://github.com/Blancochuy/emoji-styles#readme",
  "keywords": ["emoji", "icons", "design-system", "semantic-ui", "fluent-emoji", "noto-emoji", "twemoji"],
  "license": "MIT"
}
