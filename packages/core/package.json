{
  "name": "emoji-styles",
  "private": true,
  "version": "0.1.0",
  "description": "Typed multi-provider emoji URLs with licensed Fluent, Noto, Twemoji, and native renderers",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "repository": { "type": "git", "url": "git+https://github.com/JarvisBotBlanco/emoji-styles.git", "directory": "packages/core" },
  "bugs": { "url": "https://github.com/JarvisBotBlanco/emoji-styles/issues" },
  "homepage": "https://github.com/JarvisBotBlanco/emoji-styles#readme",
  "keywords": ["emoji", "icons", "react", "fluent-emoji", "noto-emoji", "twemoji"],
  "license": "MIT"
}
