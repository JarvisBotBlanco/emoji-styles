{
  "name": "emoji-styles-assets-twemoji",
  "version": "0.1.0",
  "description": "Local Twemoji 15.1.0 asset provider for Emoji Styles",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./public/emoji/twemoji/15.1.0/manifest.json",
    "./assets/*": "./public/emoji/twemoji/15.1.0/*"
  },
  "files": ["dist", "public", "LICENSE-GRAPHICS"],
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external emoji-styles",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "emoji-styles": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blancochuy/emoji-styles.git",
    "directory": "packages/assets-twemoji"
  },
  "bugs": {
    "url": "https://github.com/Blancochuy/emoji-styles/issues"
  },
  "homepage": "https://emoji-styles.space",
  "keywords": ["emoji", "twemoji", "assets", "self-hosted", "offline"],
  "license": "MIT"
}
