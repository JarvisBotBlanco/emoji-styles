{
  "name": "emoji-styles-assets-twemoji",
  "private": true,
  "version": "0.1.0",
  "description": "Local Twemoji 15.1.0 asset provider for Emoji Styles",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./public/emoji/twemoji/15.1.0/manifest.json",
    "./assets/*": "./public/emoji/twemoji/15.1.0/*"
  },
  "files": ["dist", "public", "LICENSE-GRAPHICS"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external emoji-styles",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "emoji-styles": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "sideEffects": false,
  "license": "CC-BY-4.0"
}
