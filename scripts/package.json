{
  "name": "emoji-styles-scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx generate-emoji-data.ts",
    "generate:check": "tsx generate-emoji-data.ts --check",
    "generate:validate": "tsx generate-emoji-data.ts --check",
    "generate:all": "tsx generate-emoji-data.ts",
    "assets:check": "tsx sync-open-assets.ts --dry-run",
    "assets:sync": "tsx sync-open-assets.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "tsx": "^4.19.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "sharp": "0.34.3"
  }
}
